[Unit]
Description=WB Autoreply (FastAPI / uvicorn)
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=__APP_ROOT__
EnvironmentFile=/etc/wb_autoreply.env
ExecStart=__APP_ROOT__/.venv/bin/uvicorn app.web.server:app --host 127.0.0.1 --port 8000 --loop asyncio --http h11
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
